{
  "name": "cattaneo-grid-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "prerender:gh": "ng build --configuration production --base-href=/",
    "deploy:gh": "npm run prerender:gh && npx angular-cli-ghpages --dir=dist/cattaneo-grid-app/browser --branch=gh-pages"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "xml2js": "^0.6.2",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/xml2js": "^0.4.14",
    "angular-cli-ghpages": "^3.0.2",
    "baseline-browser-mapping": "^2.10.0",
    "jsdom": "^24.1.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
